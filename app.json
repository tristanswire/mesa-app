{
  "expo": {
    "name": "Mesa",
    "slug": "mesa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F2EA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tristanswire.mesa"
    },
    "platforms": [
      "ios"
    ],
    "plugins": [
      "expo-font",
      "expo-sqlite"
    ]
  }
}
